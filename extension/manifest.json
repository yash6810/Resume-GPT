{
  "manifest_version": 3,
  "name": "ResumeGPT Scanner",
  "version": "1.0.0",
  "description": "AI-powered resume analyzer that scans job descriptions and shows ATS score, matched/missing skills, and recommendations",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.indeed.com/*",
    "*://*.glassdoor.com/*",
    "*://*.ziprecruiter.com/*",
    "*://*.monster.com/*",
    "*://localhost/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ResumeGPT Scanner"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*",
        "*://*.indeed.com/*",
        "*://*.glassdoor.com/*",
        "*://*.ziprecruiter.com/*",
        "*://*.monster.com/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ]
}
