API quick spec (so you can code without guesswork)
POST /parse

multipart form: resume (file)

returns: { text: "...", sections: { experience: "...", education: "...", skills: "..." } }

POST /analyze

body: { resume_text: "...", job_description: "..." }

returns:

{
  "ats_score": 72,
  "subscores": {"keywords": 80, "role_match": 65, "experience_relevance": 70, "quality": 60},
  "skill_matches": [{"skill":"Python","type":"exact"}],
  "missing_skills": ["SQL","AWS"],
  "recommendations": ["Add 'SQL' under skills", "Rewrite bullet xyz..."]
}
POST /rewrite

body: { "bullet": "...", "target_keywords": ["SQL","AWS"] }

returns: { "variants": ["ATS-optimized version", "Human-friendly version"] }

POST /export

body: { "resume_text": "...", "applied_changes": [...] }

returns: binary DOCX stream

